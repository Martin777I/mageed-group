# ══════════════════════════════════════════════
# MAGEED GROUP — Frontend Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── API URL ──
# Development: Leave as /api (Vite proxy handles it)
# Production: Set to your Railway/Render backend URL
VITE_API_URL=/api

# ── App Name ──
VITE_APP_NAME="MAGEED GROUP"
